# ============================================================
# .env.example — copy to `.env` and fill in real values.
# Only VITE_* values are exposed to the browser. Everything else
# is server-only and MUST NOT use the VITE_ prefix.
# ============================================================

# ---- Public (browser-visible, embedded in the client bundle) ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
VITE_SUPABASE_PROJECT_ID=your-project-ref

# ---- Server-only (read at runtime by Nitro Node process) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.your-project.supabase.co:5432/postgres

# Razorpay (payments)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace-with-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-webhook-secret

# Lovable AI Gateway (optional — only if AI features are used)
LOVABLE_API_KEY=

# ---- Runtime tuning (Nitro Node preset) ----
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# ---- Build-time only ----
# Tells Nitro to emit a Node server (default in this project is Cloudflare).
# Set this BEFORE `bun run build` / `npm run build`.
NITRO_PRESET=node-server
